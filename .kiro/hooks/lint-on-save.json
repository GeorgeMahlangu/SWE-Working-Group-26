{
  "version": "v1",
  "hooks": [
    {
      "name": "Lint on Save",
      "trigger": "PostFileSave",
      "description": "Runs ESLint on TypeScript/TSX files after each save to catch issues early",
      "matcher": "\\.(ts|tsx)$",
      "action": {
        "type": "command",
        "command": "cd /Users/vusimozi.solani/Documents/Clarity/Conference/payment-dispute-triage && npm run lint --silent 2>&1 | tail -20"
      }
    }
  ]
}
