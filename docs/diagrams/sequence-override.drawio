        <mxCell id="hB" value="OverrideModal&#10;(DisputeDetail)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="50" width="170" height="44" as="geometry" /></mxCell>
        <mxCell id="hC" value="Express Route&#10;/:id/override" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="50" width="170" height="44" as="geometry" /></mxCell>
        <mxCell id="hD" value="disputeService" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="740" y="50" width="160" height="44" as="geometry" /></mxCell>
        <mxCell id="hE" value="SQLite (Prisma)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#F0FDF4;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="960" y="50" width="140" height="44" as="geometry" /></mxCell>

        <!-- Lifelines -->
        <mxCell id="lA" style="endArrow=none;dashed=1;html=1;strokeColor=#9CA3AF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="94" as="sourcePoint" /><mxPoint x="120" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lB" style="endArrow=none;dashed=1;html=1;strokeColor=#9CA3AF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="345" y="94" as="sourcePoint" /><mxPoint x="345" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lC" style="endArrow=none;dashed=1;html=1;strokeColor=#9CA3AF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="585" y="94" as="sourcePoint" /><mxPoint x="585" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lD" style="endArrow=none;dashed=1;html=1;strokeColor=#9CA3AF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="820" y="94" as="sourcePoint" /><mxPoint x="820" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="lE" style="endArrow=none;dashed=1;html=1;strokeColor=#9CA3AF;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="94" as="sourcePoint" /><mxPoint x="1030" y="780" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Messages -->
        <mxCell id="m1" value="1: open OverrideModal" style="html=1;endArrow=block;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="135" as="sourcePoint" /><mxPoint x="345" y="135" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m2" value="2: choose action/priority, enter reason, confirm (REQ-075, 076)" style="html=1;endArrow=block;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="180" as="sourcePoint" /><mxPoint x="345" y="180" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sb" value="client check: reason 10–300, ≥1 field set" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#374151;fontColor=#111827;fontSize=10;" vertex="1" parent="1"><mxGeometry x="250" y="198" width="200" height="34" as="geometry" /></mxCell>

        <mxCell id="m3" value="3: POST /:id/override {action?, priority?, reason, operatorId}" style="html=1;endArrow=block;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="345" y="258" as="sourcePoint" /><mxPoint x="585" y="258" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sc" value="validate reason 10–300 &amp; ≥1 field (REQ-077)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=10;" vertex="1" parent="1"><mxGeometry x="495" y="276" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="mErr" value="invalid → 400/422 (no change)" style="html=1;endArrow=open;dashed=1;strokeColor=#DC2626;fontColor=#B91C1C;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="585" y="350" as="sourcePoint" /><mxPoint x="345" y="350" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="m5" value="4: applyOverride(id, payload)" style="html=1;endArrow=block;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="585" y="400" as="sourcePoint" /><mxPoint x="820" y="400" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="sd" value="reject if CLOSED (REQ-083); preserve originalAction/originalPriority; set isOverridden=true (REQ-078, 079)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFFFFF;strokeColor=#374151;fontColor=#111827;fontSize=10;" vertex="1" parent="1"><mxGeometry x="700" y="418" width="240" height="58" as="geometry" /></mxCell>

        <mxCell id="m7" value="5: UPDATE Dispute + write audit row (REQ-084)" style="html=1;endArrow=block;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="820" y="510" as="sourcePoint" /><mxPoint x="1030" y="510" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m8" value="6: persisted" style="html=1;endArrow=open;dashed=1;strokeColor=#16A34A;fontColor=#166534;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1030" y="550" as="sourcePoint" /><mxPoint x="820" y="550" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="m9" value="7: updated dispute (originals + override)" style="html=1;endArrow=open;dashed=1;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="820" y="600" as="sourcePoint" /><mxPoint x="585" y="600" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m10" value="8: 200 OK (override result)" style="html=1;endArrow=open;dashed=1;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="585" y="645" as="sourcePoint" /><mxPoint x="345" y="645" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m11" value="9: show manual-override indicator (REQ-079)" style="html=1;endArrow=open;dashed=1;strokeColor=#374151;fontColor=#111827;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="345" y="690" as="sourcePoint" /><mxPoint x="120" y="690" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="note" value="The original system recommendation and priority are never discarded — they are preserved alongside the override for audit (REQ-078)." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fillColor=#F0FDF4;strokeColor=#16A34A;fontColor=#166534;fontSize=10;rounded=1;arcSize=8;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="40" y="730" width="560" height="46" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
