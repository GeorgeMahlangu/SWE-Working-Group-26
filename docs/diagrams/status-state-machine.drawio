<mxfile host="app.diagrams.net" agent="Kiro">
  <diagram id="status-state-machine" name="Dispute Status State Machine">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Dispute Status State Machine (REQ-080–084)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#0033A0;" vertex="1" parent="1">
          <mxGeometry x="320" y="14" width="560" height="28" as="geometry" />
        </mxCell>

        <!-- Initial -->
        <mxCell id="init" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="70" y="170" width="26" height="26" as="geometry" />
        </mxCell>

        <!-- States -->
        <mxCell id="open" value="OPEN" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="160" y="150" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="inprog" value="IN_PROGRESS" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="410" y="150" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="resolved" value="RESOLVED" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="660" y="150" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="closed" value="CLOSED&#10;(immutable)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#F0FDF4;strokeColor=#16A34A;fontColor=#166534;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="910" y="150" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- Final -->
        <mxCell id="final" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#111827;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1130" y="172" width="26" height="26" as="geometry" />
        </mxCell>
        <mxCell id="finaldot" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;" vertex="1" parent="1">
          <mxGeometry x="1136" y="178" width="14" height="14" as="geometry" />
        </mxCell>

        <!-- Transitions -->
        <mxCell id="t0" value="create&#10;(system, REQ-002)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#374151;fontColor=#374151;fontSize=10;" edge="1" parent="1" source="init" target="open"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t1" value="start work" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#0033A0;fontColor=#0033A0;fontSize=11;" edge="1" parent="1" source="open" target="inprog"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2" value="resolve&#10;[note &#8805; 10 chars]&#10;(REQ-081)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#0033A0;fontColor=#0033A0;fontSize=11;" edge="1" parent="1" source="inprog" target="resolved"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t3" value="close&#10;(only from RESOLVED, REQ-082)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#0033A0;fontColor=#0033A0;fontSize=11;" edge="1" parent="1" source="resolved" target="closed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#16A34A;" edge="1" parent="1" source="closed" target="final"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Guard / rejection notes -->
        <mxCell id="g1" value="Transitions are forward-only and may not skip a state (REQ-080). Illegal transitions (e.g. OPEN&#8594;RESOLVED, or close from non-RESOLVED) are rejected — REQ-082." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fillColor=#FFF7E6;strokeColor=#D97706;fontColor=#7C2D12;fontSize=11;rounded=1;arcSize=8;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="160" y="300" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="Every transition writes an immutable StatusTransition row with operator + timestamp (REQ-084). No edits are allowed once CLOSED (REQ-083)." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=top;fillColor=#F0FDF4;strokeColor=#16A34A;fontColor=#166534;fontSize=11;rounded=1;arcSize=8;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="690" y="300" width="390" height="80" as="geometry" />
        </mxCell>

        <!-- Rejected transition illustration -->
        <mxCell id="rej" value="OPEN &#8594; RESOLVED" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#B91C1C;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="430" width="190" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rejedge" value="rejected (400)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;dashed=1;strokeColor=#DC2626;fontColor=#B91C1C;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="open" target="resolved"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="245" y="470" /><mxPoint x="745" y="470" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
