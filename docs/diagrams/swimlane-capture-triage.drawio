        <mxCell id="s1" value="Click &#8220;New Dispute&#8221;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF7E6;strokeColor=#B45309;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="90" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="Render capture form&#10;(GET /api/enums &#8212; REQ-007)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#374151;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="170" width="240" height="50" as="geometry" />
        </mxCell>
