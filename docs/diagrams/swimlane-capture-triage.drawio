          <mxGeometry x="60" y="250" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="Client-side validation&#10;(REQ-009, REQ-125)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="320" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="POST /api/disputes&#10;Server-side validation&#10;(REQ-003&#8211;009)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="610" y="410" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="Assign queue; compute&#10;age, ageBand, dueDate&#10;(REQ-025&#8211;028, 010&#8211;020)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#374151;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="540" width="260" height="56" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="Evaluate rules in&#10;precedence order;&#10;first match wins (REQ-030&#8211;048)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="630" width="220" height="56" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="Apply 7/14-day modifiers&#10;(REQ-018, 019); build ruleId,&#10;explanation, factors (REQ-050&#8211;053)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#EFF6FF;strokeColor=#2563EB;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="710" width="220" height="56" as="geometry" />
