<mxfile host="app.diagrams.net" agent="Kiro">
  <diagram id="swimlane-capture-triage" name="Swimlane — Capture &amp; Triage">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1440" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Swimlane — Capture a Dispute &amp; Automatic Triage (Journeys 1 &amp; 2)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#0033A0;" vertex="1" parent="1">
          <mxGeometry x="300" y="8" width="840" height="28" as="geometry" />
        </mxCell>

        <!-- Lanes -->
        <mxCell id="lane1" value="Operations User" style="swimlane;startSize=30;html=1;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=13;swimlaneFillColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="260" height="1100" as="geometry" />
        </mxCell>
        <mxCell id="lane2" value="React Frontend" style="swimlane;startSize=30;html=1;fillColor=#EAF0FB;strokeColor=#0033A0;fontColor=#0033A0;fontStyle=1;fontSize=13;swimlaneFillColor=#FFFFFF;" vertex="1" parent="1">
