        <mxCell id="s11" value="201 Created&#10;(full dispute + triage)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFFFFF;strokeColor=#374151;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="890" width="260" height="50" as="geometry" />
